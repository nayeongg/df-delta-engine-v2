TZ=Asia/Seoul

# NiFi-IdP compose 가 붙어 있는 Docker network 이름
# 예: docker network ls 로 확인한 실제 이름
DELTA_DOCKER_NETWORK=nifi-idp_nifi-net

# delta-postgres 초기 계정
POSTGRES_DB=delta_db
POSTGRES_USER=delta_user
POSTGRES_PASSWORD=delta_pass

# Postgres 데이터 적재 위치
POSTGRES_DATA_DIR=./postgres-data

# delta 엔진 HTTP 노출
# 호스트에서는 127.0.0.1:18089 로만 접근하고,
# NiFi 컨테이너에서는 같은 docker network 안에서
# http://df-delta-engine-v2:8082 로 접근
DELTA_HTTP_BIND=127.0.0.1
DELTA_HTTP_PORT=18089

# 테이블은 미리 만들어두는 방식이므로 기본은 validate
DF_DELTA_JPA_DDL_AUTO=validate
